{
  "name": "内容平台配色方案",
  "description": "适合公众号、知乎、博客等平台的 Markdown 排版配色",
  "themes": [
    {
      "id": "typo",
      "name": "typo.css",
      "file": "typo.css",
      "source": "https://github.com/sofish/typo.css",
      "license": "MIT",
      "author": "sofish",
      "description": "中文网页重设与排版，一致化浏览器排版效果",
      "features": [
        "中文排版优化",
        "跨浏览器一致",
        "响应式设计",
        "专名号/着重号支持"
      ],
      "colors": {
        "background": "#ffffff",
        "text": "#333333",
        "link": "#1abc9c",
        "heading": "#333333"
      },
      "fontSize": {
        "base": "16px",
        "h1": "24px",
        "h2": "20px",
        "h3": "18px"
      },
      "lineHeight": 1.75,
      "suitable": ["公众号文章", "中文文档", "博客文章"]
    },
    {
      "id": "smartisan",
      "name": "锤子便签风格",
      "file": "smartisan.css",
      "source": "https://github.com/nihaojob/markdown-css-smartisan",
      "license": "MIT",
      "author": "nihaojob",
      "description": "复刻锤子便签经典风格，温暖配色",
      "features": [
        "温暖米黄背景",
        "中文友好",
        "长文阅读优化",
        "简洁优雅"
      ],
      "colors": {
        "background": "#fefcf3",
        "text": "#333333",
        "link": "#1abc9c",
        "heading": "#333333"
      },
      "fontSize": {
        "base": "16px",
        "h1": "24px",
        "h2": "20px",
        "h3": "18px"
      },
      "lineHeight": 1.75,
      "suitable": ["公众号文章", "长文排版", "个人博客"]
    },
    {
      "id": "smartisan-dark",
      "name": "锤子便签暗色",
      "file": "smartisan-dark.css",
      "source": "https://github.com/nihaojob/markdown-css-smartisan",
      "license": "MIT",
      "author": "nihaojob",
      "description": "锤子便签风格暗色模式",
      "features": [
        "暗色护眼",
        "夜间阅读友好",
        "保留锤子便签风格"
      ],
      "colors": {
        "background": "#1a1a1a",
        "text": "#e0e0e0",
        "link": "#6dd5c7",
        "heading": "#e0e0e0"
      },
      "suitable": ["夜间阅读", "暗色主题偏好"]
    },
    {
      "id": "github-light",
      "name": "GitHub Light",
      "file": "github-light.css",
      "source": "https://github.com/sindresorhus/github-markdown-css",
      "license": "MIT",
      "author": "sindresorhus",
      "description": "GitHub 官方 Markdown 亮色样式",
      "features": [
        "GitHub 官方风格",
        "开发者熟悉",
        "代码高亮友好"
      ],
      "colors": {
        "background": "#ffffff",
        "text": "#24292f",
        "link": "#0969da",
        "heading": "#24292f"
      },
      "suitable": ["技术文章", "开发者博客", "开源文档"]
    },
    {
      "id": "github-dark",
      "name": "GitHub Dark",
      "file": "github-dark.css",
      "source": "https://github.com/sindresorhus/github-markdown-css",
      "license": "MIT",
      "author": "sindresorhus",
      "description": "GitHub 官方 Markdown 暗色样式",
      "features": [
        "GitHub 暗色模式",
        "护眼",
        "夜间阅读友好"
      ],
      "colors": {
        "background": "#0d1117",
        "text": "#c9d1d9",
        "link": "#58a6ff",
        "heading": "#c9d1d9"
      },
      "suitable": ["夜间阅读", "暗色主题偏好", "技术文章"]
    },
    {
      "id": "normalize",
      "name": "Normalize.css",
      "file": "normalize.css",
      "source": "https://github.com/necolas/normalize.css",
      "license": "MIT",
      "author": "necolas",
      "description": "跨浏览器样式一致性基础层",
      "features": [
        "样式重置",
        "跨浏览器一致",
        "HTML5 支持"
      ],
      "suitable": ["所有项目的样式基础"]
    },
    {
      "id": "sakura",
      "name": "Sakura",
      "file": "sakura.css",
      "source": "https://github.com/oxalorg/sakura",
      "license": "MIT",
      "author": "oxalorg",
      "description": "极简 classless CSS，适合独立博客与长文阅读",
      "features": [
        "极简长文阅读",
        "低依赖",
        "系统字体栈",
        "单文件可直接使用"
      ],
      "colors": {
        "background": "#f9f9f9",
        "text": "#4a4a4a",
        "link": "#1f6feb",
        "heading": "#222222"
      },
      "fontSize": {
        "base": "18px",
        "h1": "2em",
        "h2": "1.8em",
        "h3": "1.6em"
      },
      "lineHeight": 1.618,
      "suitable": ["独立博客", "长文阅读", "内容发布页"]
    },
    {
      "id": "water",
      "name": "Water Light",
      "file": "water.css",
      "source": "https://github.com/kognise/water.css",
      "license": "MIT",
      "author": "Kognise",
      "description": "通用内容页 classless CSS，适合博客正文与轻内容站点",
      "features": [
        "通用内容页",
        "低依赖",
        "响应式",
        "表格/引用开箱即用"
      ],
      "colors": {
        "background": "#ffffff",
        "text": "#363636",
        "link": "#0076d1",
        "heading": "#000000"
      },
      "fontSize": {
        "base": "16px",
        "h1": "2.2em",
        "h2": "1.8em",
        "h3": "1.4em"
      },
      "lineHeight": 1.4,
      "suitable": ["博客正文", "通用内容页", "技术文章"]
    }
  ],
  "recommendations": {
    "公众号文章": ["normalize.css", "smartisan.css"],
    "技术博客": ["normalize.css", "github-light.css", "water.css"],
    "夜间阅读": ["normalize.css", "github-dark.css"],
    "中文文档": ["normalize.css", "typo.css"],
    "独立博客/长文阅读": ["sakura.css", "water.css"],
    "Typora长文写作/发布前预览": ["../typora/notion-light-enhanced.css"]
  },
  "typography": {
    "fontFamily": {
      "chinese": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", \"PingFang SC\", \"Hiragino Sans GB\", \"Microsoft YaHei\", sans-serif",
      "heading": "\"PingFang SC\", \"Hiragino Sans GB\", \"Microsoft YaHei\", sans-serif"
    },
    "lineHeight": {
      "body": 1.75,
      "heading": 1.3
    },
    "fontSize": {
      "h1": "24px",
      "h2": "20px",
      "h3": "18px",
      "body": "16px",
      "quote": "15px",
      "footnote": "14px"
    },
    "spacing": {
      "paragraph": "1.5em",
      "indent": "2em"
    }
  }
}
